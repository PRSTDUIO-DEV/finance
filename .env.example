# -----------------------------------------------------------------------------
# Viewton Home - Environment Variables Template
# -----------------------------------------------------------------------------

# [Required] Database connection string
# Format: mysql://USERNAME:PASSWORD@HOST:PORT/DATABASE_NAME
DATABASE_URL="mysql://db_user:your_secure_password@localhost:3306/viewton_db"

# [Required] Secret key for signing session cookies
# Generate a random string for this (e.g., using `openssl rand -hex 32`)
JWT_SECRET="your_super_secret_jwt_key_please_change_this"

# [Required] Unique application identifier
VITE_APP_ID="viewton-finance-app"

# [Required] URL for the central OAuth server for login
OAUTH_SERVER_URL="https://auth.yourdomain.com"

# [Optional] Application environment (use "production" on ServerAvatar)
NODE_ENV="production"

# [Optional] Port for the server to listen on (ServerAvatar handles this via Proxy/Supervisor)
PORT="3000"

# [Optional] OpenID of the super admin/owner
# OWNER_OPEN_ID="your_admin_open_id"

# [Optional] External API integrations (Forge / AI)
# BUILT_IN_FORGE_API_URL="https://api.your-forge.com"
# BUILT_IN_FORGE_API_KEY="your_api_key_here"
